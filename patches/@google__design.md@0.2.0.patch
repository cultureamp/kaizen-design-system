diff --git a/dist/index.js b/dist/index.js
index c3a4e6ec25fffea5d61d110419c48f7357bc462a..e2754e1ec94fdcc741242d7047e59937d8b16dfe 100755
--- a/dist/index.js
+++ b/dist/index.js
@@ -21120,6 +21120,8 @@ var CSS_NAMED_COLORS = {
   transparent: "#00000000"
 };
 function parseCssColor(colorStr) {
+  if (typeof colorStr !== "string")
+    return null;
   const clean = colorStr.trim().toLowerCase();
   if (!clean)
     return null;
@@ -21347,6 +21349,8 @@ function parseAlpha(s) {
   return parseFloat(trim);
 }
 function tokenizeFunc(str) {
+  if (typeof str !== "string")
+    return null;
   const match = str.trim().match(/^([a-z-]{3,15})\((.*)\)$/i);
   if (!match)
     return null;
@@ -21616,6 +21620,8 @@ var CSS_UNITS = new Set([
   "%"
 ]);
 function parseDimensionParts(raw) {
+  if (typeof raw !== "string")
+    return null;
   const match = raw.match(/^(-?\d*\.?\d+)([a-zA-Z%]+)$/);
   if (!match)
     return null;
@@ -21630,6 +21636,8 @@ function isParseableDimension(raw) {
   return parts !== null && CSS_UNITS.has(parts.unit);
 }
 function isTokenReference(raw) {
+  if (typeof raw !== "string")
+    return false;
   return /^\{[a-zA-Z0-9._-]+\}$/.test(raw);
 }
 
