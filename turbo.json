{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "docs#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["**/*.d.ts", "**/*.js", "**/*.map", "dist/**"],
      "inputs": ["packages/**", "draft-packages/**"]
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "outputs": ["dist/**"]
    },
    "test": {},
    "@kaizen/components#build": {
      "dependsOn": ["@kaizen/tailwind#build", "@kaizen/design-tokens#build"],
      "inputs": ["src/**"],
      "outputs": ["dist/**"]
    },
    "@kaizen/tailwind#build": {
      "dependsOn": ["@kaizen/design-tokens#build"],
      "inputs": ["src/**"],
      "outputs": ["dist/**"]
    },
    "@kaizen/design-tokens#build": {
      "inputs": ["css/**", "less/**", "sass/**", "src/**", "tokens/**"],
      "outputs": ["dist/**"]
    }
  }
}
